# VicNail Studio - Environment Variables Template
# Copy this file to .env.local and fill in the values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
SUPABASE_SECRET_KEY=your-supabase-service-role-key

# Admin Authentication
ADMIN_GATE_CODE=your-admin-gate-code
ADMIN_PASSWORD=your-strong-admin-password
# Admin session token 簽章密鑰：建議獨立設定強隨機值。
# 未設定時退回以 ADMIN_PASSWORD 衍生；若兩者皆未設定則 admin 一律拒絕（fail-closed）。
ADMIN_SESSION_SECRET=your-random-admin-session-secret

# Article API
ARTICLE_API_KEY=your-article-api-key

# ECPay 綠界（金流 + 物流）
ECPAY_MERCHANT_ID=your-ecpay-merchant-id
ECPAY_HASH_KEY=your-ecpay-hash-key
ECPAY_HASH_IV=your-ecpay-hash-iv
ECPAY_SANDBOX=true

# LINE Messaging API（訂貨群組機器人）
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# n8n Webhooks
N8N_GROUPBUY_WEBHOOK=https://your-n8n.zeabur.app/webhook/groupbuy-notify

# Site URL（ECPay callback 用）
NEXT_PUBLIC_SITE_URL=https://vicnail-studio.com

# ─────────────────────────────────────────────────────────────
# 線上課程平台（Bunny.net Stream）
# 在 https://dash.bunny.net/stream 申請 Stream Library 取得：
#   Library ID（URL 內的數字）
#   API Key（Library settings > API）
#   CDN Hostname（vz-xxxxxxxx-xxx.b-cdn.net）
#   Token Authentication Key（Security 頁面，用於簽 Signed URL）
# ─────────────────────────────────────────────────────────────
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_CDN_HOSTNAME=
BUNNY_STREAM_TOKEN_AUTH_KEY=

# 藍新 Newebpay（選配，作為 ECPay 之外的金流選項）
# NEWEBPAY_MERCHANT_ID=
# NEWEBPAY_HASH_KEY=
# NEWEBPAY_HASH_IV=
# NEWEBPAY_SANDBOX=true

# Feature Flags
NEXT_PUBLIC_ADS_ENABLED=false
